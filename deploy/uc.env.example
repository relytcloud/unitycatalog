# Copy to uc.env and fill in. uc.env holds real secrets and is gitignored — never commit it.
#
#   cp uc.env.example uc.env && edit uc.env
#   ./deploy-uc.sh

# --- Persistent root ---
# Point this at a persistent (cloud-disk) path. server.properties, hibernate.properties,
# relyt_jwks.json and the H2 metastore DB all live under it, so nothing is lost on restart.
# Default if unset: the UC repo root (two levels up from demo/deploy).
UC_HOME=

# --- Auth / token-exchange ---
# enable = require auth (per-user token-exchange); disable = no auth.
UC_AUTHORIZATION=enable
# Relyt instance id(s), comma-separated. Must match the JWK "issuer" members in the JWKS file.
UC_ALLOWED_ISSUERS=1024
# Expected audience of the subject tokens (must match the signer's unity.audience).
UC_AUDIENCES=unitycatalog-server
# Exchanged access-token TTL (ISO-8601). Blank = no expiry (opt-in).
UC_ACCESS_TOKEN_TTL=PT1H

# --- Aliyun OSS (master RAM identity for STS AssumeRole) ---
ALIYUN_REGION=cn-hangzhou
ALIYUN_ACCESS_KEY=<your-aliyun-access-key-id>
ALIYUN_SECRET_KEY=<your-aliyun-access-key-secret>
# The master RAM principal ARN (the user/role the UC server runs as).
ALIYUN_MASTER_ROLE_ARN=acs:ram::<account-id>:user/<master-ram-user>

# --- Path overrides (optional) ---
# All default to under UC_HOME; set only to relocate an individual file off UC_HOME.
# UC_SERVER_PROPERTIES=$UC_HOME/etc/conf/server.properties
# UC_HIBERNATE_PROPERTIES=$UC_HOME/etc/conf/hibernate.properties
# UC_EXTERNAL_JWKS_FILE=$UC_HOME/etc/conf/relyt_jwks.json
# UC_DB_FILE=$UC_HOME/etc/db/h2db
